{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "server/*": ["../server/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../server/src/**/*.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
