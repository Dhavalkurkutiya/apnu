{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@apnu/auth": "workspace:*",
    "@apnu/db": "workspace:*",
    "@apnu/env": "workspace:*",
    "@hono/node-ws": "^1.3.0",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.8.2",
    "ioredis": "^5.10.1",
    "nanoid": "^5.1.7",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@apnu/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "catalog:"
  },
  "trustedDependencies": [
    "supabase"
  ]
}
